VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
# Optional — only if you still want it in Firebase config; uploads use Cloudinary, not Firebase Storage.
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Comma-separated admin emails (lowercase). Must match firestore.rules.
VITE_ADMIN_EMAILS=admin@yourcollege.edu

# Optional: restrict sign-in to these email domains (comma-separated).
VITE_ALLOWED_EMAIL_DOMAINS=

# Cloudinary unsigned upload (Settings → Upload → Upload presets)
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
